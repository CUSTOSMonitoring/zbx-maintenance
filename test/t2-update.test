# Ejemplo de comando update para el mantenimiento de test2
./src/run_maintenance.sh --zbx-user "${ZBX_USER}" --zbx-password "${ZBX_PASS}" \
    update \
    --name "[Web Mantenimientos] Mantenimiento de Prueba desde MaintenanceHandler: v2" \
    --startdate "2026-01-03 14:00:00" \
    --period 12h \
    --sector "test"
